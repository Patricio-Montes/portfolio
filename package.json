{
  "name": "patricio-montes-portfolio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "generate:cv": "node --import tsx scripts/generate-cv-pdfs.mjs",
    "build": "npm run generate:cv && next build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "npm run generate:cv && node --import tsx --test tests/*.test.mjs",
    "verify": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.3",
    "@types/node": "26.1.1",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "pdfkit": "^0.19.1",
    "tailwindcss": "4.3.3",
    "tsx": "^4.23.1",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
